# Banking Service Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.

# Application
APP_NAME=banking-service
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Auth / JWT
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite:///./banking.db

# Server
HOST=0.0.0.0
PORT=8000
